extends layout

block content
    .row.banner
        .col-12
            h1 Starcups
           
    .row
        .col-12.col-lg-9
            .row 
                .col-12.col-md-6
                    p.rating
                        i.fas.fa-star
                        i.fas.fa-star
                        i.fas.fa-star
                        i.far.fa-star
                        i.far.fa-star
                    p 125 High Street, Reading RG6 1PS
                    .card.card-primary.mt-2.mb-2 
                        .card-body 
                            h2.card-title Opening hours 
                            p.card-text Monday - Friday : 7:00am - 7:00pm
